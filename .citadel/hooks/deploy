#!/usr/bin/env bash
# Citadel deploy hook for Citadel itself.
#
# Contract (subcommands and structured I/O):
#   $1 = subcommand
#     list                 → stdout JSON: {"apps":[{"name":"citadel","url":"http://<host>:<port>"}]}
#                           must complete in ≤10s; no side effects.
#     redeploy [name]      → (re)starts the named app, or all apps if no name.
#                           stdout/stderr stream back to the cockpit operation log.
#
# What this hook starts:
#   The worktree-local daemon (apps/daemon) on a derived port. The daemon also
#   serves the bundled cockpit (apps/web/dist) from the same origin, so the UI
#   and the /api routes always come from this branch's build — no Vite proxy,
#   no risk of the cockpit hitting a different daemon (e.g. the systemd main
#   one on 4010) and seeing routes from a different branch.
#
# Delegates the actual build+start to `make -s deploy-worktree`, which is the
# canonical worktree deploy path. This hook exists so the cockpit's "Redeploy"
# button reuses the same flow.
#
# Environment provided by Citadel:
#   CITADEL_WORKSPACE_ID    — opaque workspace id
#   CITADEL_WORKSPACE_PATH  — absolute path to the worktree (same as cwd)
#   CITADEL_WORKSPACE_BRANCH
#   CITADEL_REPO_ID
#
# Optional override:
#   CITADEL_PUBLIC_HOST     — host to advertise in the URL (defaults to the
#                            machine's primary non-loopback IPv4, falling back
#                            to 127.0.0.1). Set this if your machine has
#                            multiple NICs and you want a specific one in the
#                            cockpit chip.
#
# Port derivation: prefer the port persisted in .citadel/dev.json (the daemon
# writes this on boot, including after EADDRINUSE fallback). Fall back to
# `4110 + (cksum($WORKTREE_PATH) mod 100)` — same formula the Makefile uses —
# when dev.json is missing (no daemon has booted from this worktree yet).

set -euo pipefail

APP_NAME="citadel"
WORKTREE="${CITADEL_WORKSPACE_PATH:-$(pwd)}"

derive_port() {
  local dev_state="$WORKTREE/.citadel/dev.json"
  if [[ -r "$dev_state" ]] && command -v jq >/dev/null 2>&1; then
    local persisted
    persisted=$(jq -r '.port // empty' "$dev_state" 2>/dev/null || true)
    if [[ -n "$persisted" ]]; then
      printf '%d' "$persisted"
      return
    fi
  fi
  local sum
  sum=$(printf '%s' "$WORKTREE" | cksum | awk '{print $1}')
  printf '%d' $(( 4110 + (sum % 100) ))
}

derive_host() {
  if [[ -n "${CITADEL_PUBLIC_HOST:-}" ]]; then
    printf '%s' "$CITADEL_PUBLIC_HOST"
    return
  fi
  # Prefer the machine's first non-loopback IPv4 so the cockpit URL is
  # reachable from other LAN hosts. Fall back to 127.0.0.1 only if no public
  # address resolves (e.g. inside a container with only lo).
  local ip
  if command -v hostname >/dev/null 2>&1; then
    ip=$(hostname -I 2>/dev/null | awk '{ for (i=1;i<=NF;i++) if ($i !~ /^127\./ && $i ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/) { print $i; exit } }')
  fi
  if [[ -z "${ip:-}" ]] && command -v ip >/dev/null 2>&1; then
    ip=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -n1)
  fi
  printf '%s' "${ip:-127.0.0.1}"
}

PORT="$(derive_port)"
HOST="$(derive_host)"
URL="http://${HOST}:${PORT}"

case "${1:-}" in
  list)
    printf '%s\n' "{\"apps\":[{\"name\":\"${APP_NAME}\",\"url\":\"${URL}\"}]}"
    ;;
  redeploy)
    name="${2:-}"
    if [[ -n "$name" && "$name" != "$APP_NAME" ]]; then
      echo "unknown app: $name (only '${APP_NAME}' is exposed by this hook)" >&2
      exit 2
    fi
    if ! command -v make >/dev/null 2>&1; then
      echo "make not found in PATH — required to delegate to the canonical worktree deploy" >&2
      exit 127
    fi
    cd "$WORKTREE"
    echo "→ Delegating to 'make serve' (worktree=${WORKTREE})"
    # `make serve` is the build + detached daemon path. (`make deploy` is
    # foreground HMR and would hang this hook.) It handles: build, stop prior
    # daemon, free the port, start the new daemon detached via setsid+nohup,
    # record pgid under .citadel/logs. Streams progress to this hook's
    # stdout/stderr so the cockpit operation log shows the live build + boot.
    make -s serve
    echo "${APP_NAME} reachable at ${URL}"
    ;;
  ""|--help|-h|help)
    cat <<EOF
usage: $(basename "$0") <list|redeploy [name]>
  list                emit JSON describing exposed apps
  redeploy [name]     (re)start an app, or all apps if no name
EOF
    ;;
  *)
    echo "unknown subcommand: $1" >&2
    exit 2
    ;;
esac
