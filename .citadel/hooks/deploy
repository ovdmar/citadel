#!/usr/bin/env bash
# Citadel deploy hook for Citadel itself.
#
# Contract (subcommands and structured I/O):
#   $1 = subcommand
#     list                 → stdout JSON: {"apps":[{"name":"citadel","url":"http://<host>:<port>"}]}
#                           must complete in ≤10s; no side effects.
#     redeploy [name]      → (re)starts the named app, or all apps if no name.
#                           stdout/stderr stream back to the cockpit operation log.
#
# What this hook starts:
#   The worktree-local HMR dev stack via `make -s deploy`: a daemon (tsx watch)
#   on a derived port + vite (HMR) on another derived port, both detached under
#   one process group. The advertised URL is the vite cockpit URL — that's the
#   one with HMR, so subsequent source edits show up live without re-clicking
#   Redeploy.
#
# Delegates to `make -s deploy` so the cockpit's Redeploy chip and a developer
# in a terminal trigger the exact same flow.
#
# Environment provided by Citadel:
#   CITADEL_WORKSPACE_ID    — opaque workspace id
#   CITADEL_WORKSPACE_PATH  — absolute path to the worktree (same as cwd)
#   CITADEL_WORKSPACE_BRANCH
#   CITADEL_REPO_ID
#
# Optional override:
#   CITADEL_PUBLIC_HOST     — host to advertise in the URL (defaults to the
#                            machine's primary non-loopback IPv4, falling back
#                            to 127.0.0.1). Set this if your machine has
#                            multiple NICs and you want a specific one in the
#                            cockpit chip.
#
# Port derivation: prefer ports persisted in .citadel/dev.json (the daemon
# writes the daemon port on boot; the Makefile seeds webPort the first time
# `make deploy` runs). Fall back to cksum-derived defaults when dev.json is
# missing (no daemon has booted from this worktree yet). We advertise the
# *web* port — that's the vite cockpit with HMR; the daemon port is plumbing.

set -euo pipefail

APP_NAME="citadel"
WORKTREE="${CITADEL_WORKSPACE_PATH:-$(pwd)}"

dev_state_field() {
  local field="$1"
  local file="$WORKTREE/.citadel/dev.json"
  if [[ -r "$file" ]] && command -v jq >/dev/null 2>&1; then
    jq -r ".$field // empty" "$file" 2>/dev/null || true
  fi
}

derive_port() {
  local persisted
  persisted=$(dev_state_field port)
  if [[ -n "$persisted" ]]; then printf '%d' "$persisted"; return; fi
  local sum
  sum=$(printf '%s' "$WORKTREE" | cksum | awk '{print $1}')
  printf '%d' $(( 4110 + (sum % 100) ))
}

derive_web_port() {
  local persisted
  persisted=$(dev_state_field webPort)
  if [[ -n "$persisted" ]]; then printf '%d' "$persisted"; return; fi
  local sum
  sum=$(printf '%s' "$WORKTREE/web" | cksum | awk '{print $1}')
  printf '%d' $(( 5210 + (sum % 100) ))
}

derive_host() {
  if [[ -n "${CITADEL_PUBLIC_HOST:-}" ]]; then
    printf '%s' "$CITADEL_PUBLIC_HOST"
    return
  fi
  # Prefer the machine's first non-loopback IPv4 so the cockpit URL is
  # reachable from other LAN hosts. Fall back to 127.0.0.1 only if no public
  # address resolves (e.g. inside a container with only lo).
  local ip
  if command -v hostname >/dev/null 2>&1; then
    ip=$(hostname -I 2>/dev/null | awk '{ for (i=1;i<=NF;i++) if ($i !~ /^127\./ && $i ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/) { print $i; exit } }')
  fi
  if [[ -z "${ip:-}" ]] && command -v ip >/dev/null 2>&1; then
    ip=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -n1)
  fi
  printf '%s' "${ip:-127.0.0.1}"
}

WEB_PORT="$(derive_web_port)"
HOST="$(derive_host)"
URL="http://${HOST}:${WEB_PORT}"

case "${1:-}" in
  list)
    printf '%s\n' "{\"apps\":[{\"name\":\"${APP_NAME}\",\"url\":\"${URL}\"}]}"
    ;;
  redeploy)
    name="${2:-}"
    if [[ -n "$name" && "$name" != "$APP_NAME" ]]; then
      echo "unknown app: $name (only '${APP_NAME}' is exposed by this hook)" >&2
      exit 2
    fi
    if ! command -v make >/dev/null 2>&1; then
      echo "make not found in PATH — required to delegate to the canonical worktree deploy" >&2
      exit 127
    fi
    cd "$WORKTREE"
    echo "→ Delegating to 'make deploy' (worktree=${WORKTREE})"
    # `make deploy` is the canonical dev command for both terminals and this
    # hook. It's detached HMR: stops the previous pgid, starts daemon (tsx
    # watch) + vite under one process group, polls the daemon's /api/state
    # until ready, then returns. Streams progress to this hook's stdout/stderr
    # so the cockpit operation log shows the live boot output. Subsequent
    # source edits hot-reload — clicking Redeploy again only matters when you
    # want a clean restart.
    make -s deploy
    echo "${APP_NAME} reachable at ${URL}"
    ;;
  ""|--help|-h|help)
    cat <<EOF
usage: $(basename "$0") <list|redeploy [name]>
  list                emit JSON describing exposed apps
  redeploy [name]     (re)start an app, or all apps if no name
EOF
    ;;
  *)
    echo "unknown subcommand: $1" >&2
    exit 2
    ;;
esac
