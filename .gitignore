packages/*/src/*.js
packages/*/src/*.d.ts
apps/*/src/*.js
apps/*/src/*.d.ts
# .client.js files are intentionally-checked-in browser-side source loaded
# at runtime via fs.readFileSync (e.g. terminal-key-shim.client.js), not
# tsc emit. Force-include them so they ship in the git tree.
!packages/*/src/*.client.js
!apps/*/src/*.client.js
